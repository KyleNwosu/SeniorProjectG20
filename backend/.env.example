ROBOT_IP=192.168.1.10
ROBOT_PORT=10000
ROBOT_USERNAME=admin
ROBOT_PASSWORD=admin
BRIDGE_PORT=8000
CAMERA_INDEX=0
# Optional: use a network camera stream instead of local webcam.
# Example: rtsp://<user>:<pass>@<robot-ip>/stream
CAMERA_SOURCE_URL=
# Linux: v4l2 | macOS: avfoundation | Windows: dshow/msmf
CAMERA_BACKEND=v4l2
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_JPEG_QUALITY=80
